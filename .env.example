# Copy to .env and edit. `.env` is gitignored. Shell env vars override these.
#
# Scripted mode (the default) needs NONE of the GCP settings — it runs entirely
# offline. You only need the GCP/CXAS settings below for LIVE mode (real agent).

# ---- GCP / CXAS (required for LIVE mode only) ----
# Your Google Cloud project that has the CES API (ces.googleapis.com) enabled.
GCP_PROJECT_ID=
GCP_PROJECT_NUMBER=
# CES/CXAS region. Use "us" (the API returns 404 for "global").
GCP_LOCATION=us

# Set automatically by scripts/create_agent.py after it provisions the agent.
# It is the deployed app's full resource path:
#   projects/<PROJECT_NUMBER>/locations/us/apps/<APP_ID>
# Leave blank before first provisioning.
CXAS_APP_NAME=
CXAS_AGENT_ID=
CXAS_DEPLOYMENT_ID=

# ---- Agent provisioning (used by scripts/create_agent.py) ----
# Change these to deploy your own independent copy of the agent. Also overridable
# per run via CLI flags: --display-name / --app-id / --model.
CXAS_APP_DISPLAY_NAME=Booking.com Concierge Demo
CXAS_APP_ID=booking-concierge
CXAS_MODEL=gemini-2.5-flash

# Optional: service-account JSON path (otherwise Application Default Credentials).
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Client-side pacing for the CES per-minute "RunSession LLM tokens" quota.
# This default assumes a fast project with improved quota. Lower it if you see 429s.
CXAS_REQUESTS_PER_MINUTE=30

# ---- Demo mode ----
DEMO_MODE=scripted   # "scripted" (offline, default) or "live" (real CXAS agent)

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:8000
VITE_DEMO_MODE=scripted   # initial UI mode; "scripted" or "live"
